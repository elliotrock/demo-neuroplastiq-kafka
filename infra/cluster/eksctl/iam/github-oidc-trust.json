{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Federated": "arn:aws:iam::755267562381:oidc-provider/token.actions.githubusercontent.com"
      },
      "Action": "sts:AssumeRoleWithWebIdentity",
      "Condition": {
        "StringEquals": {
          "token.actions.githubusercontent.com:sub": [
            "repo:neuro-group/demo-neuroplastiq-kafka:environment:dev",
            "repo:neuro-group/demo-neuroplastiq-kafka:environment:staging",
            "repo:neuro-group/demo-neuroplastiq-kafka:environment:prod"
          ],
          "token.actions.githubusercontent.com:aud": "sts.amazonaws.com"
        }
      }
    }
  ]
}
